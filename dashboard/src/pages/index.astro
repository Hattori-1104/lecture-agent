---
import { readFileSync, readdirSync } from 'node:fs';
import { resolve, join } from 'node:path';
import Layout from '../layouts/Layout.astro';
import { TopicCard } from '../components/TopicCard';
import { SessionHistory } from '../components/SessionHistory';
import { Card, CardContent } from '../components/ui/card';

// data/ ディレクトリはリポジトリルートにある
const dataDir = resolve(process.cwd(), '..', 'data');

// progress.json を読み込む
let progress = {
  lastUpdated: null as string | null,
  topics: {} as Record<string, {
    understanding: number;
    attempts: number;
    correct: number;
    weakPoints: string[];
    lastPracticed: string | null;
  }>,
  overallStats: { totalSessions: 0, totalProblems: 0, totalCorrect: 0 },
};
try {
  const raw = readFileSync(join(dataDir, 'progress.json'), 'utf-8');
  progress = { ...progress, ...JSON.parse(raw) };
} catch { /* 初回ビルド時は空データ */ }

// sessions/ を glob して読み込む
interface Session {
  id: string;
  date: string;
  topicsCovered: string[];
  problemsAttempted: number;
  problemsCorrect: number;
  summary: string;
  weakPointsIdentified: string[];
}
let sessions: Session[] = [];
try {
  const sessionDir = join(dataDir, 'sessions');
  const files = readdirSync(sessionDir).filter(f => f.endsWith('.json'));
  sessions = files.map(f => JSON.parse(readFileSync(join(sessionDir, f), 'utf-8')));
} catch { /* sessions/ が空または未作成 */ }

const { overallStats } = progress;
const overallAccuracy = overallStats.totalProblems > 0
  ? Math.round((overallStats.totalCorrect / overallStats.totalProblems) * 100)
  : null;

const topicEntries = Object.entries(progress.topics)
  .sort(([, a], [, b]) => a.understanding - b.understanding);

// トピックをカテゴリ別にグループ化
const grouped = topicEntries.reduce<Record<string, typeof topicEntries>>((acc, entry) => {
  const [name] = entry;
  const category = name.includes('/') ? name.split('/')[0] : 'その他';
  (acc[category] ??= []).push(entry);
  return acc;
}, {});

const lastUpdated = progress.lastUpdated
  ? new Date(progress.lastUpdated).toLocaleDateString('ja-JP', {
      year: 'numeric', month: 'long', day: 'numeric', hour: '2-digit', minute: '2-digit',
    })
  : null;
---

<Layout title="大学数学 学習ダッシュボード">
  <div class="max-w-5xl mx-auto px-4 py-10">

    <!-- ヘッダー -->
    <div class="mb-10">
      <h1 class="text-3xl font-bold text-foreground mb-1">大学数学 学習ダッシュボード</h1>
      {lastUpdated && (
        <p class="text-sm text-muted-foreground">最終更新: {lastUpdated}</p>
      )}
    </div>

    <!-- 全体統計 -->
    <div class="grid grid-cols-3 gap-4 mb-12">
      <Card size="sm">
        <CardContent className="text-center">
          <div class="text-4xl font-bold text-primary">{overallStats.totalSessions}</div>
          <div class="text-sm text-muted-foreground mt-1">セッション数</div>
        </CardContent>
      </Card>
      <Card size="sm">
        <CardContent className="text-center">
          <div class="text-4xl font-bold text-primary">{overallStats.totalProblems}</div>
          <div class="text-sm text-muted-foreground mt-1">解いた問題数</div>
        </CardContent>
      </Card>
      <Card size="sm">
        <CardContent className="text-center">
          <div class="text-4xl font-bold text-primary">
            {overallAccuracy !== null ? `${overallAccuracy}%` : '—'}
          </div>
          <div class="text-sm text-muted-foreground mt-1">全体正解率</div>
        </CardContent>
      </Card>
    </div>

    <!-- トピック別 -->
    {topicEntries.length === 0 ? (
      <Card className="p-8 text-center mb-12">
        <CardContent>
          <p class="text-muted-foreground">学習を始めると、トピックごとの進捗がここに表示されます。</p>
        </CardContent>
      </Card>
    ) : (
      <div class="mb-12">
        <h2 class="text-xl font-semibold text-foreground mb-5">トピック別 理解度</h2>
        {Object.entries(grouped).map(([category, entries]) => (
          <div class="mb-8">
            <h3 class="text-sm font-medium text-muted-foreground uppercase tracking-wider mb-3">{category}</h3>
            <div class="grid grid-cols-1 sm:grid-cols-2 gap-4">
              {entries.map(([name, data]) => (
                <TopicCard
                  name={name.includes('/') ? name.split('/').slice(1).join('/') : name}
                  understanding={data.understanding}
                  attempts={data.attempts}
                  correct={data.correct}
                  weakPoints={data.weakPoints}
                  lastPracticed={data.lastPracticed}
                />
              ))}
            </div>
          </div>
        ))}
      </div>
    )}

    <!-- セッション履歴 -->
    <div>
      <h2 class="text-xl font-semibold text-foreground mb-5">セッション履歴</h2>
      <SessionHistory sessions={sessions} />
    </div>

  </div>
</Layout>
