---
import ProgressBar from './ProgressBar.astro';
interface Props {
  name: string;
  understanding: number;
  attempts: number;
  correct: number;
  weakPoints: string[];
  lastPracticed: string | null;
}
const { name, understanding, attempts, correct, weakPoints, lastPracticed } = Astro.props;
const accuracy = attempts > 0 ? Math.round((correct / attempts) * 100) : null;
---

<div class="bg-card rounded-2xl p-5 flex flex-col gap-3 border border-border hover:shadow-md transition-shadow">
  <div class="flex items-start justify-between gap-2">
    <h3 class="font-semibold text-card-foreground leading-snug">{name}</h3>
    {lastPracticed && (
      <span class="text-xs text-muted-foreground whitespace-nowrap shrink-0 pt-0.5">{lastPracticed}</span>
    )}
  </div>

  <ProgressBar value={understanding} label="理解度" />

  {accuracy !== null && (
    <div class="text-sm text-muted-foreground">
      正解率 <span class="text-foreground font-medium">{accuracy}%</span>
      <span class="text-muted-foreground mx-1">·</span>
      {correct}/{attempts} 問
    </div>
  )}

  {weakPoints.length > 0 && (
    <div>
      <p class="text-xs text-muted-foreground mb-1.5">苦手点</p>
      <ul class="flex flex-wrap gap-1.5">
        {weakPoints.map((wp) => (
          <li class="text-xs bg-destructive/10 text-destructive rounded-full px-2.5 py-0.5 border border-destructive/20">
            {wp}
          </li>
        ))}
      </ul>
    </div>
  )}
</div>
